<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="franka_hand">

    <xacro:include filename="$(find franka_description)/final_urdf/gripper/gripper_utils.xacro" />

    <xacro:property name="ee_inertials" value="${xacro.load_yaml('$(find franka_description)/config/gripper_inertials.yaml')}"/>

    <xacro:property name="hand_mount_xyz" value="0 0 0"/>
    <xacro:property name="hand_mount_rpy" value="0 0 ${-pi/4}"/>

    <xacro:property name="tcp_xyz" value="0 0 0.1034"/>
    <xacro:property name="tcp_rpy" value="0 0 0"/>




    <!-- ======================================================================================================================
     =====================================Edit from Here ========================================================================-->

  
  <!-- safety_distance: Minimum safety distance in [m] by which the collision volumes are expanded and which is enforced during robot motions -->
  <xacro:macro name="franka_hand">
    
    <joint name="hand_joint" type="fixed">
        <origin xyz="${hand_mount_xyz}"
                rpy="${hand_mount_rpy}"/>
        <parent link="link8"/>
        <child link="hand"/>
    </joint>

    <xacro:fr3-hand-link name="hand"/>

    <!-- Define the hand_tcp frame -->
     <link name="hand_tcp"/>
    
    <joint name="hand_tcp_joint" type="fixed">
        <origin xyz="${tcp_xyz}"
                rpy="${tcp_rpy}"/>
        <parent link="hand"/>
        <child link="hand_tcp"/>
    </joint>



    <link name="leftfinger">
      <visual name="leftfinger_visual">
        <geometry>
          <mesh filename="package://franka_description/meshes/franka_hand_white/visual/finger.dae" />
        </geometry>
      </visual>
      <!-- screw mount -->
      <collision>
        <origin xyz="0 18.5e-3 11e-3" rpy="0 0 0" />
        <geometry> 
          <box size="22e-3 15e-3 20e-3" />
        </geometry>
      </collision>
      <!-- cartriage sledge -->
      <collision>
        <origin xyz="0 6.8e-3 2.2e-3" rpy="0 0 0" />
        <geometry>
          <box size="22e-3 8.8e-3 3.8e-3" />
        </geometry>
      </collision>
      <!-- diagonal finger -->
      <collision>
        <origin xyz="0 15.9e-3 28.35e-3" rpy="${pi/6} 0 0" />
        <geometry>
          <box size="17.5e-3 7e-3 23.5e-3" />
        </geometry>
      </collision>
      <!-- rubber tip with which to grasp -->
      <collision>
        <origin xyz="0 7.58e-3 45.25e-3" rpy="0 0 0" />
        <geometry>
          <box size="17.5e-3 15.2e-3 18.5e-3" />
        </geometry>
      </collision>
      <!-- <xacro:ee-inertials name="leftfinger" /> -->
      <xacro:ee-inertials
    name="leftfinger"
    ee_inertials="${ee_inertials}"/>
    </link>
    
    <link name="rightfinger">
      <visual name="rightfinger_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://franka_description/meshes/franka_hand_white/visual/finger.dae" />
        </geometry>
      </visual>
      <!-- screw mount -->
      <collision>
        <origin xyz="0 18.5e-3 11e-3" rpy="0 0 0" />
        <geometry>
          <box size="22e-3 15e-3 20e-3" />
        </geometry>
      </collision>
      <!-- cartriage sledge -->
      <collision>
        <origin xyz="0 6.8e-3 2.2e-3" rpy="0 0 0" />
        <geometry>
          <box size="22e-3 8.8e-3 3.8e-3" />
        </geometry>
      </collision>
      <!-- diagonal finger -->
      <collision>
        <origin xyz="0 15.9e-3 28.35e-3" rpy="${-pi/6} 0 ${pi}" />
        <geometry>
          <box size="17.5e-3 7e-3 23.5e-3" />
        </geometry>
      </collision>
      <!-- rubber tip with which to grasp -->
      <collision>
        <origin xyz="0 7.58e-3 45.25e-3" rpy="0 0 0" />
        <geometry>
          <box size="17.5e-3 15.2e-3 18.5e-3" />
        </geometry>
      </collision>
      <!-- <xacro:ee-inertials name="rightfinger" /> -->
      <xacro:ee-inertials
    name="rightfinger"
    ee_inertials="${ee_inertials}"/>
    </link>
    <joint name="finger_joint1" type="prismatic">
      <parent link="hand" />
      <child link="leftfinger" />
      <origin xyz="0 0 0.0584" rpy="0 0 0" />
      <axis xyz="0 1 0" />
      <limit effort="100" lower="0.0" upper="0.04" velocity="0.2" />
      <dynamics damping="0.3" />
    </joint>
    <joint name="finger_joint2" type="prismatic">
      <parent link="hand" />
      <child link="rightfinger" />
      <origin xyz="0 0 0.0584" rpy="0 0 ${pi}" />
      <axis xyz="0 1 0" />
      <limit effort="100" lower="0.0" upper="0.04" velocity="0.2" />
      <dynamics damping="0.3" />
    </joint>
  </xacro:macro>
</robot>
